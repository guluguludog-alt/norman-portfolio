<file path="src/components/programming.css">
@import url('https://fonts.googleapis.com/css2?family=Dela+Gothic+One&display=swap');
@font-face {
  font-family: 'SonsieOne';
  src: url('/fonts/SonsieOne-Regular.ttf') format('truetype');
}

.programming-page {
  width: 100vw;
  height: auto; 
  background-color: #000000;
  position: relative;
  z-index: 10;
  overflow: hidden; 
  /* 🌟 性能优化 1：渲染隔离，告诉浏览器这里的动画绝不影响外部排版 */
  contain: paint layout;
}

.programming-video-container {
  width: 100%;
  height: auto; 
  position: relative;
  z-index: 1; 
  display: flex;
  flex-direction: column; 
  justify-content: center; 
  align-items: center; 
  box-sizing: border-box;
  padding: 0; 
  overflow: hidden; 
}

.video-tight-wrapper {
  position: relative;
  display: block; 
  width: 100vw;        
  height: auto;        
  line-height: 0; 
  font-size: 0;
  z-index: 10; 
}

.programming-scroll-video {
  display: block;
  width: 100%;    
  height: auto;        
  object-fit: contain; 
  z-index: 2;
  border-radius: 0; 
  position: relative;
}

@keyframes simpleFadeIn {
  0% { opacity: 0; filter: blur(20px); -webkit-filter: blur(20px); }
  100% { opacity: 1; filter: blur(0px); -webkit-filter: blur(0px); }
}

@keyframes simpleFadeOut {
  0% { opacity: 1; filter: blur(0px); -webkit-filter: blur(0px); visibility: visible; }
  /* 🌟 性能优化 2：渐出动画结束后彻底隐藏，切断渲染树消耗 */
  100% { opacity: 0; filter: blur(20px); -webkit-filter: blur(20px); visibility: hidden; }
}

.history-layout-container { position: absolute; inset: 0; z-index: 30; display: flex; align-items: center; justify-content: center; padding: 0 10%; gap: 4%; pointer-events: none; animation: simpleFadeIn 2s ease-in-out both; will-change: filter, opacity; container-type: inline-size; }
.history-left-side { flex: 1.2; display: flex; justify-content: flex-end; }
.history-window-image { width: auto; max-width: 45%; height: auto; max-height: 70%; object-fit: contain; }
.history-right-side { flex: 0.8; display: flex; justify-content: flex-start; padding-left: 2%; }
.powered-by-text { font-family: 'Dela Gothic One', -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "华文黑体", "STHeiti", "Segoe UI", Arial, "Microsoft YaHei", "微软雅黑", sans-serif; color: #ffffff; font-size: clamp(2rem, 5.5cqw, 6rem); line-height: 1.15; text-align: left; margin: 0; }

.bar-content-wrapper { position: absolute; inset: 0; pointer-events: none; z-index: 30; will-change: filter, opacity; container-type: inline-size;}
.bar-content-wrapper.bar-exit { animation: simpleFadeOut 0.8s ease-in both; }
.bar-title-wrapper { position: absolute; top: 25%; left: 50%; transform: translate(-50%, -50%); width: 95%; display: flex; justify-content: center; }
.bar-title { font-family: 'Dela Gothic One', -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "华文黑体", "STHeiti", "Segoe UI", Arial, "Microsoft YaHei", "微软雅黑", sans-serif; color: #ffffff; margin: 0; letter-spacing: 1px; text-align: center; white-space: nowrap; font-size: 4.6cqw; line-height: 1.1; animation: simpleFadeIn 0.85s ease-out 0.8s both; }
.bar-image-wrapper { position: absolute; bottom: 25%; left: 50%; transform: translate(-50%, 50%); width: 75%; display: flex; justify-content: center; }
.bar-image { width: 100%; height: auto; object-fit: contain; animation: simpleFadeIn 0.85s ease-out 0.9s both; }

/* 🌟 性能优化 3：平时设置为 visibility: hidden，彻底阻止高斯模糊和伪层在后台偷吃 GPU */
.video-glow-overlay { position: absolute; inset: 0; z-index: 10; pointer-events: none; opacity: 0; visibility: hidden; mix-blend-mode: screen; overflow: hidden; border-radius: 0; transition: opacity 0.8s ease-out, visibility 0s 0.8s; }
.video-glow-overlay.glow-active { opacity: 1; visibility: visible; transition: opacity 0.8s ease-out, visibility 0s; }

.glow-system { position: absolute; top: -100px; bottom: -100px; left: -100px; right: -100px; filter: blur(28px) brightness(1.5) saturate(4); }
.glow-color { position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; }
.glow-color-1 { background: conic-gradient(from 0deg, transparent 10%, #0033ff 30%, #ff003c 50%, transparent 60%); animation: rotateGlow 2s linear infinite; }
.glow-color-2 { background: conic-gradient(from 180deg, transparent 10%, #00ff22 30%, #ffea00 50%, transparent 60%); animation: rotateGlowReverse 3s linear infinite; mix-blend-mode: screen; }
.glow-black-hole { position: absolute; top: 130px; bottom: 130px; left: 130px; right: 130px; background: rgba(0, 0, 0, 0.85); border-radius: 0; z-index: 2; }

@keyframes rotateGlow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
@keyframes rotateGlowReverse { from { transform: rotate(360deg); } to { transform: rotate(0deg); } }

.clipo-interface-wrapper { position: absolute; inset: 0; z-index: 40; display: flex; flex-direction: column; justify-content: center; align-items: center; pointer-events: none; gap: 24px; padding-top: 20px; box-sizing: border-box; will-change: filter, opacity; }
.clipo-interface-wrapper.clipo-exit { animation: simpleFadeOut 1.2s ease-in both; }
.clipo-interface-image { max-width: 55%; max-height: 55%; animation: simpleFadeIn 1.1s ease-out 0.2s both; }
.clipo-text-group { text-align: center; }
.clipo-text-top { font-family: 'Dela Gothic One', -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "华文黑体", "STHeiti", "Segoe UI", Arial, "Microsoft YaHei", "微软雅黑", sans-serif; font-size: clamp(2rem, 4vw, 3.2rem); color: #fff; margin: 0; animation: simpleFadeIn 1.4s ease-out 0.05s both; }
.clipo-text-bottom { font-family: 'SonsieOne', -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "华文黑体", "STHeiti", "Segoe UI", Arial, "Microsoft YaHei", "微软雅黑", sans-serif; font-size: clamp(2.8rem, 5.5vw, 4.5rem); color: #0016d8; margin: 0; animation: simpleFadeIn 1.4s ease-out 0.15s both; }
.fade-out-all { animation: simpleFadeOut 1.5s ease-in both; pointer-events: none; }

.macbook-overlay-image { position: absolute; width: 131.2%; height: auto; max-width: none; z-index: 50; pointer-events: none; }

.apple-imac-layer,
.apple-macstudio-layer,
.sync-text-container,
.sweep2-buttons-row {
  position: absolute;
  top: 50%;
  left: 50%;
  pointer-events: none;
}

/* =========================================
   🌟 全局公用文字属性
   ========================================= */
.sync-text-container h2 {
  font-family: 'Dela Gothic One', -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "华文黑体", "STHeiti", "Segoe UI", Arial, "Microsoft YaHei", "微软雅黑", sans-serif;
  line-height: 1.25;
  white-space: pre-line;
  padding-bottom: 0.2em;
  margin: 0;
  color: transparent;
  -webkit-background-clip: text;
  background-clip: text;
  background-repeat: no-repeat;
  background-size: 150% 100%; 
}

/* 按钮通用属性 */
.sweep2-btn {
  display: flex; align-items: center; justify-content: center;
  background: #ffffff; border: none; 
  border-radius: clamp(8px, 1vw, 12px);
  padding: clamp(8px, 1vw, 14px) clamp(16px, 2vw, 28px);
  cursor: pointer;
  font-family: 'Dela Gothic One', -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "华文黑体", "STHeiti", "Segoe UI", Arial, "Microsoft YaHei", "微软雅黑", sans-serif; 
  font-size: clamp(0.7rem, 1vw, 1.1rem);
  color: #000000; letter-spacing: 1px;
  transition: box-shadow 0.2s ease; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
}

.sweep2-btn:hover { box-shadow: 0 6px 25px rgba(0, 0, 0, 0.5); }
.sweep2-btn-icon { width: clamp(16px, 1.5vw, 26px); height: auto; object-fit: contain; }
.sweep2-btn-hover-text { font-family: 'Dela Gothic One', -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "华文黑体", "STHeiti", "Segoe UI", Arial, "Microsoft YaHei", "微软雅黑", sans-serif; font-size: clamp(0.6rem, 0.8vw, 1rem); color: #666666; letter-spacing: 1px; white-space: nowrap; }

.programming-play-container { position: absolute; bottom: 30px; right: 30px; z-index: 60; display: flex; align-items: center; gap: 12px; pointer-events: auto; }
.programming-play-label { font-family: 'SansSerifFLF', 'Georgia', serif; font-size: clamp(12px, 1.2vw, 15px); color: rgba(255, 255, 255, 0.7); letter-spacing: 3px; }
.programming-play-icon { cursor: pointer; transition: transform 0.2s ease; flex-shrink: 0; }
.programming-play-icon:hover { transform: scale(1.15); }
.programming-play-icon img { width: clamp(40px, 5vw, 60px); height: auto; object-fit: contain; filter: drop-shadow(0 0 10px rgba(0, 0, 0, 0.5)); }


/* =========================================
   🌟 移动端专属响应式核心 (<= 900px)
   ========================================= */
@media (max-width: 900px) {
  .programming-page, .programming-video-container {
    min-height: 100vh;
  }
  
  .video-tight-wrapper {
    display: flex; 
    justify-content: center;
    align-items: center;
    height: 100vh;          
    aspect-ratio: 16 / 9;   
    width: auto;            
    flex-shrink: 0;         
  }

  .programming-scroll-video {
    height: 100%;
    object-fit: cover;      
  }

  .apple-imac-layer {
    display: none !important; 
  }

  .apple-macstudio-layer {
    width: 135px; 
    z-index: 20; 
  }

  .sync-text-container {
    width: 85vw; 
    text-align: left;
  }
  
  .sync-text-container h2,
  .sync-text-second h2 {
    text-align: left;
    padding: 0; 
    font-size: clamp(2.875rem, 7.125vw, 5.25rem) !important; 
  }
  
  .sweep2-buttons-row {
    width: 85vw; 
    display: flex;
    flex-direction: row; 
    flex-wrap: nowrap; 
    justify-content: flex-start; 
    align-items: center;
    padding: 0;
    pointer-events: auto;
    gap: clamp(10px, 1.5vw, 20px);
  }

  .history-layout-container {
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
    padding: 0 5vw;
    box-sizing: border-box;
  }

  .history-left-side {
    flex: 1;
    justify-content: flex-end;
  }

  .history-window-image {
    max-width: 100%;
    max-height: 45vh;
  }

  .history-right-side {
    flex: 1;
    padding-left: 4vw;
  }

  .powered-by-text {
    font-size: clamp(1.8rem, 6vw, 3.5rem);
    white-space: normal; 
    line-height: 1.2;
  }

  .bar-content-wrapper {
    width: 100vw;
    left: 50%;
    transform: translateX(-50%);
  }

  .bar-title {
    font-size: clamp(1.2rem, 5vw, 2.5rem);
    white-space: normal;
  }
}

/* =========================================
   🌟 中文模式：使用标准中文字体栈，移除 Dela Gothic One / SonsieOne
   ========================================= */
.zh-lang .sweep2-btn,
.zh-lang .sweep2-btn-hover-text,
.zh-lang .sync-text-container h2 {
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "华文黑体", "STHeiti", "Segoe UI", Arial, "Microsoft YaHei", "微软雅黑", sans-serif !important;
}

/* =========================================
   🌟 PC 端响应式核心 (> 900px)
   ========================================= */
@media (min-width: 901px) {
  .apple-imac-layer { width: 38vw; height: auto; z-index: 5; }
  .apple-macstudio-layer { width: 13vw; height: auto; z-index: 20; }
  
  .sync-text-container { width: 40vw; text-align: left; }
  
  .sync-text-container h2,
  .sync-text-second h2 {
    padding: 0 5vw; 
    font-size: clamp(1.4rem, 4vw, 5.2rem) !important; 
  }
  
  .sweep2-buttons-row { 
    width: 40vw; 
    display: flex;
    flex-direction: row;
    justify-content: flex-start; 
    pointer-events: auto; 
    padding: 0 5vw; 
    gap: clamp(10px, 1.5vw, 20px);
  }
}
