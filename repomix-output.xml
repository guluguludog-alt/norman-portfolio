/* =========================================
    AIGC Works Page
    ========================================= */
.aigc-portfolio-section {
    background-color: #000000;
    position: relative;
    width: 100vw;
    /* 精确计算的滚动空间，用于满足 3/4 触发和结束溢出 200px 的数学条件 */
    height: calc(500vh - 600px); 
    z-index: 10;
}

.aigc-sticky-container {
    position: sticky;
    top: 0;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
}

/* =========================================
    视频容器
    ========================================= */
.aigc-video-container {
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1; /* 底层 */
}

/* =========================================
    页面标题
    ========================================= */
.aigc-titles {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 5; /* 在视频之上，但在 Ring 之下 */
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.aigc-main-wrapper {
    font-family: 'Dela Gothic One', "Segoe UI", Arial, sans-serif;
    font-size: 9rem;
    font-weight: 900;
    color: #0016d8;
    line-height: 1;
}

.aigc-sub-wrapper {
    font-family: 'Dela Gothic One', "Segoe UI", Arial, sans-serif;
    font-size: 4.5rem;
    font-weight: 900;
    color: #0016d8;
    line-height: 1;
}

.aigc-title-char {
    color: inherit;
}

/* =========================================
   响应式
   ========================================= */
@media (max-width: 900px) {
    .aigc-portfolio-section {
        margin: 0;
        padding: 0;
        /* 移动端没有 Ring 动画，大幅减少滚动空间 */
        height: calc(200vh - 200px);
    }

    .aigc-sticky-container {
        position: sticky;
        top: 0;
    }

    .aigc-video-container {
        width: 100%;
        height: 100%;
        margin: 0;
        padding: 0;
    }

    .aigc-scroll-video {
        object-fit: cover;
        object-position: calc(50% - 100px) center;
    }

    .aigc-main-wrapper {
        font-size: 16vw;
    }

    .aigc-sub-wrapper {
        font-size: 8vw;
    }

    .aigc-ring {
        display: none;
    }
}

/* =========================================
    Ring 图片
    ========================================= */
.aigc-ring {
    position: absolute;
    top: 230%;
    left: 50%;
    width: 210vw;
    transform: translate(-50%, -50%);
    z-index: 10; /* 中间层：确保盖住标题和视频 */
    pointer-events: none;
    will-change: top, width;
}

/* =========================================
    视频本体
    ========================================= */
.aigc-scroll-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
}
