/* =========================================
   Experience List Page 基础设置
   ========================================= */
.experience-list-page {
  position: relative;
  width: 100%;
  height: auto;          
  min-height: 60vh;      
  padding: 15vh 0;
  background-color: black; 
  z-index: 90; 
  overflow: hidden; 
}

/* 视差背景层 */
.parallax-star-bg {
  position: absolute;
  top: -10%; 
  left: 0;
  width: 100%;
  height: 120%; 
  background-size: 100% 100%; 
  background-position: center;      
  background-repeat: no-repeat;     
  z-index: 1; 
  pointer-events: none; 
}

/* =========================================
   公司列表排版容器
   ========================================= */
.company-list-container {
  position: relative;
  z-index: 5; 
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 40px; 
  padding: 0 10%; 
}

.company-item {
  cursor: pointer; 
  width: 100%;
  text-align: center;
  position: relative;
}

/* =========================================
   字体排版 & 扫光遮罩组合特效
   ========================================= */

.company-text-wrapper {
  position: relative;
  display: inline-block;
  width: 100%;
  transform-origin: center center; 
  /* 🌟 核心修改：将渐变遮罩移到父盒子，这样光标到达两侧边缘时会被自然隐没 */
  -webkit-mask-image: linear-gradient(
    to right, 
    rgba(0, 0, 0, 0) 0%, 
    rgba(0, 0, 0, 1) 15%, 
    rgba(0, 0, 0, 1) 85%, 
    rgba(0, 0, 0, 0) 100%
  );
  mask-image: linear-gradient(
    to right, 
    rgba(0, 0, 0, 0) 0%, 
    rgba(0, 0, 0, 1) 15%, 
    rgba(0, 0, 0, 1) 85%, 
    rgba(0, 0, 0, 0) 100%
  );
}

.original-text {
  position: relative;
  z-index: 1;
  display: inline-block;
  width: 100%;
}

.reveal-text {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  pointer-events: none;
  
  background-image: none !important;
  -webkit-text-fill-color: #0016d8 !important; 
  color: #0016d8 !important;
  text-shadow: 0 0 15px rgba(0, 22, 216, 0.6), 0 0 30px rgba(82, 17, 221, 0.5);
}

.reveal-content {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap; /* 允许换行 */
  gap: 1.5rem; /* 减小间距以便换行 */
