<file path="src/components/Navbar.jsx">
import React, { useState, useRef, useEffect } from 'react'; 
import GlassSurface from './GlassSurface'; 
import './Navbar.css';
import MenuIcon from '../assets/MenuIcon.png';
import { motion, AnimatePresence } from 'framer-motion';
import { useTranslation } from 'react-i18next';

const menuVariants = {
  hidden: { y: '-100%', transition: { duration: 0.4, ease: [0.22, 1, 0.36, 1] } },
  visible: { 
    y: 0, 
    transition: { 
      duration: 0.5, 
      ease: [0.22, 1, 0.36, 1],
      staggerChildren: 0.1,
      delayChildren: 0.15
    } 
  }
};

const linkVariants = {
  hidden: { y: -30, opacity: 0 },
  visible: { 
    y: 0, 
    opacity: 1, 
    transition: { type: "spring", stiffness: 300, damping: 24 } 
  }
};

export default function Navbar() { 
  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);
  const [isMoreHovered, setIsMoreHovered] = useState(false);
  const moreDropdownRef = useRef(null);
  const moreTriggerRef = useRef(null);
  const { t, i18n } = useTranslation();

  const toggleLanguage = () => {
    const newLang = i18n.language === 'en' ? 'zh' : 'en';
    i18n.changeLanguage(newLang);
  };

  // Close dropdown when clicking outside
  useEffect(() => {
    const handleClickOutside = (e) => {
      if (moreDropdownRef.current && !moreDropdownRef.current.contains(e.target) &&
          moreTriggerRef.current && !moreTriggerRef.current.contains(e.target)) {
        setIsMoreHovered(false);
      }
    };
    document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, []);

  return (
    <>
      {/* 1. Desktop Layout */}
      <div className="desktop-nav">
        {/* 导航栏容器（液态玻璃） */}
        <header className="navbar-wrapper">
          <GlassSurface 
            width="800px"       
            height="40px"       
            borderRadius={30}   
            blur={15}           
            opacity={0.8}       
            className="navbar-glass" 
          >
            <nav className="nav-links">
              <a href="#aigc">{t('navbar.aigc')}</a>
              <a href="#architecture">{t('navbar.architecture')}</a>
              <a href="#landscape">{t('navbar.landscape')}</a>
              <div 
                className="more-dropdown-wrapper"
                onMouseEnter={() => setIsMoreHovered(true)}
                onMouseLeave={() => setIsMoreHovered(false)}
              >
                <a href="#myspace" ref={moreTriggerRef} onClick={(e) => e.preventDefault()}>{t('navbar.more')}</a>
                <AnimatePresence>
                  {isMoreHovered && (
                    <motion.div
                      ref={moreDropdownRef}
                      className="more-dropdown-menu"
                      initial={{ opacity: 0, y: -10, x: '-50%' }}
                      animate={{ opacity: 1, y: 0, x: '-50%' }}
                      exit={{ opacity: 0, y: -10, x: '-50%' }}
                      transition={{ duration: 0.25, ease: [0.22, 1, 0.36, 1] }}
                    >
                      <a href="#programming" className="more-dropdown-item" onClick={() => setIsMoreHovered(false)}>Vibe-Coding</a>
                      <a href="#myspace" className="more-dropdown-item" onClick={() => setIsMoreHovered(false)}>My Space</a>
                    </motion.div>
                  )}
                </AnimatePresence>
              </div>
            </nav>
          </GlassSurface>
        </header>

        {/* 右侧独立按钮组 (语言切换和 Contact me) */}
        <div className="right-nav-group">
          <button className="lang-btn" onClick={toggleLanguage}>
            {i18n.language === 'en' ? '中文' : 'EN'}
          </button>
          <a 
            href="#contact" 
            className="contact-btn"
          >
            {t('navbar.contactMe')}
          </a>
        </div>
      </div>

      {/* 2. Mobile Layout */}
      <div className="mobile-nav">
        <button 
          className="mobile-menu-btn" 
          onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}
        >
          <img src={MenuIcon} alt="Menu" />
        </button>

        <AnimatePresence>
          {isMobileMenuOpen && (
            <motion.div 
              className="mobile-fullscreen-menu"
              initial="hidden"
              animate="visible"
              exit="hidden"
              variants={menuVariants}
              style={{
                position: 'fixed',
                top: 0, left: 0, width: '100vw', height: '100vh',
                backgroundColor: '#0016d8',
                zIndex: 1999,
                display: 'flex',
                flexDirection: 'column',
                justifyContent: 'center',
                alignItems: 'center'
              }}
            >
              <nav className="mobile-fullscreen-nav-links">
                {[
                  { name: t('navbar.aigc'), href: '#aigc' },
                  { name: t('navbar.architecture'), href: '#architecture' },
                  { name: t('navbar.landscape'), href: '#landscape' },
                  { name: t('navbar.more'), href: '#myspace' },
                  { name: i18n.language === 'en' ? '中文' : 'EN', isButton: true },
                  { name: t('navbar.contactMe'), href: '#contact' }
                ].map((item, idx) => (
                  <motion.div key={idx} variants={linkVariants}>
                    {item.isButton ? (
                      <button className="mobile-fullscreen-link" onClick={() => { toggleLanguage(); setIsMobileMenuOpen(false); }}>{item.name}</button>
                    ) : (
                      <a href={item.href} className="mobile-fullscreen-link" onClick={() => setIsMobileMenuOpen(false)}>{item.name}</a>
                    )}
                  </motion.div>
                ))}
              </nav>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </>
  );
}
</file>

<file path="src/App.css">
/* =========================================
   基础重置与全局设置 (包含 React 的 #root)
   ========================================= */
@font-face {
    font-family: 'Aquatico';
    src: url('/fonts/Aquatico-Regular.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
}

@font-face {
    font-family: 'SansSerifFLF';
    src: url('/fonts/SansSerifFLF.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body,
html,
#root {
    width: 100%;
    min-height: 100vh;
    background-color: #000;
    color: #fff;
    overflow-x: hidden;
    overflow-x: clip;

    font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, "PingFang SC", "Hiragino Sans GB", "华文黑体", "STHeiti", "Segoe UI", Arial, "Microsoft YaHei", "微软雅黑", sans-serif;
}

::-webkit-scrollbar {
    width: 0px;
    background: transparent;
}

/* 背景闪烁动画 */
@keyframes flicker {
    0% { opacity: 0.7; }
    50% { opacity: 1; }
    100% { opacity: 0.7; }
}

/* =========================================
   每个全屏页面区块通用样式 
   ========================================= */
.section,
.generated-content-page,
.programming-page {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    z-index: 10;
    /* 🌟 已彻底移除 content-visibility: auto，防止边界抖动 */
}

/* =========================================
   第一页：首页 (Hero)
   ========================================= */
#home {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 1;
}

.bg-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    overflow: hidden;
}

.bg-layer {
    position: absolute;
    top: -5%;
    left: -5%;
    width: 110%;
    height: 110%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.bg-layer-1 { z-index: 1; }
.bg-layer-2 { z-index: 2; mix-blend-mode: screen; opacity: 0.8; }

/* 主大字 */
.title-main {
    position: absolute;
    left: 8vw;
    top: 45%;
    transform: translateY(-50%);
    z-index: 10;
    transition: all 0.5s ease;
}

.title-main h1 {
    font-family: 'SansSerifFLF', "PingFang SC", "STHeiti", "华文黑体", "Microsoft YaHei", "微软雅黑", sans-serif;
    font-size: 10rem;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 1px;
    text-shadow: 0 4px 25px rgba(0, 0, 0, 0.9);
}

/* 名字 */
.title-name {
    position: absolute;
    right: 5vw;
    bottom: 22vh;
    z-index: 10;
    transition: all 0.5s ease;
}

.title-name h2 {
    font-family: 'Aquatico', "Segoe UI", Arial, sans-serif;
    font-style: normal;
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.9);
}

@media (max-width: 900px) {
    .title-main {
        left: 0;
        width: 100%;
        text-align: center;
        display: flex;
        justify-content: center;
    }
    .title-main h1 { font-size: 18vw; }

    .title-name {
        left: 0;
        right: 0;
        bottom: 15vh;
        width: 100%;
        text-align: center;
        display: flex;
        justify-content: center;
    }
    .title-name h2 { font-size: 9vw; }
}

/* 滚动提示动画 */
.scroll-indicator {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    font-size: 14px;
    animation: bounce 2s infinite ease-in-out;
    cursor: pointer;
    text-shadow: 0 2px 5px rgba(0, 0, 0, 0.8);
}

.scroll-arrow {
    margin-top: 5px;
    width: 20px;
    height: 20px;
    border-bottom: 2px solid #fff;
    border-right: 2px solid #fff;
    transform: rotate(45deg);
}

@keyframes bounce {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 15px); }
}

/* =========================================
   作品展示页 (Portfolio Section)
   ========================================= */
.portfolio-section { background-color: #03102c; }

.diffuse-light {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at center, rgba(10, 80, 255, 0.3) 0%, rgba(3, 16, 44, 0) 50%);
    z-index: 0;
    animation: moveLight 15s infinite alternate linear;
    pointer-events: none;
}

@keyframes moveLight {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(10%, 5%) scale(1.2); }
    100% { transform: translate(-5%, 15%) scale(0.9); }
}

.hover-bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 0.6s ease;
    z-index: 1;
    filter: blur(10px) brightness(0.4);
}

.section-title {
    position: relative;
    z-index: 10;
    padding-left: 10vw;
    margin-top: -5vh;
}

.section-title h2 {
    font-size: 4rem;
    font-weight: bold;
    line-height: 1.1;
    text-shadow: 0 4px 15px rgba(0, 0, 0, 0.8);
}

.section-title span { font-weight: 300; font-size: 3rem; }

.gallery-wrapper {
    position: relative;
    width: 100%;
    margin-top: 10vh;
    z-index: 10;
    -webkit-mask-image: linear-gradient(to right, rgba(0, 0, 0, 1) 60%, rgba(0, 0, 0, 0) 100%);
    mask-image: linear-gradient(to right, rgba(0, 0, 0, 1) 60%, rgba(0, 0, 0, 0) 100%);
}

.gallery-track {
    display: flex;
    gap: 40px;
    overflow-x: auto;
    padding: 50px 0 50px 10vw;
    scrollbar-width: none;
}

.gallery-track::-webkit-scrollbar { display: none; }

.gallery-item {
    min-width: 400px;
    height: 250px;
    position: relative;
    cursor: pointer;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), filter 0.4s ease;
    filter: grayscale(100%);
    transform: translateZ(0);
    backface-visibility: hidden;
    will-change: transform, filter;
}

.gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
}

.gallery-item .project-title {
    position: absolute;
    bottom: 15px;
    right: 20px;
    font-size: 1.2rem;
    opacity: 0;
    transition: opacity 0.3s;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.8);
}

.gallery-item:hover {
    filter: grayscale(0%);
    transform: scale(1.02) translateZ(0);
    z-index: 20;
}

.gallery-item:hover .project-title { opacity: 1; }

.scroll-hint {
    position: absolute;
    right: 15vw;
    bottom: 15vh;
    font-size: 14px;
    z-index: 10;
    text-align: right;
    opacity: 0.7;
}

/* =========================================
   字体类控制修复 (跨平台适配)
   ========================================= */
.keep-my-font, .keep-my-font span {
    font-family: 'SansSerifFLF', "PingFang SC", "STHeiti", "华文黑体", "Microsoft YaHei", "微软雅黑", sans-serif !important;
    font-weight: 400 !important;
}

.keep-my-font-name, .keep-my-font-name span {
    font-family: 'Aquatico', "Segoe UI", Arial, sans-serif !important;
    font-weight: 400 !important;
}

.keep-my-font-3, .keep-my-font-3 span {
    font-family: 'Dela Gothic One', "Segoe UI", Arial, sans-serif !important;
    font-weight: 900 !important;
}
