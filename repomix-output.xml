  useVelocity
} from 'framer-motion';
import { ReactLenis, useLenis } from 'lenis/react';
import { useNavigate } from 'react-router-dom';
import { useTranslation } from 'react-i18next';
import './architectureWorks.css';

import Project1 from "../assets/Project1.jpg";
