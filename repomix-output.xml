<file path="src/components/projects/LProject1.css">
.lproject1-page {
  padding: 120px 40px;
  min-height: 200vh;
}

.lproject1-page .project-hero-title {
  font-size: 4rem;
  font-family: 'Dela Gothic One', sans-serif;
  margin-bottom: 20px;
  color: #ffffff;
}

.lproject1-page .project-description {
  font-size: 1.2rem;
  color: #888888;
  max-width: 800px;
  line-height: 1.6;
}

.lproject1-page .project-placeholder-gallery {
  margin-top: 100px;
  width: 100%;
  height: 600px;
  background-color: #111111;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lproject1-page .project-placeholder-gallery span {
  color: #444444;
}
</file>

<file path="src/components/projects/LProject1.jsx">
import React from 'react';
import { motion } from 'framer-motion';
import './LProject1.css';

export default function LProject1() {
  return (
    <div className="project-detail-page lproject1-page">
      <motion.div 
        initial={{ opacity: 0, y: 50 }}
        animate={{ opacity: 1, y: 0 }}
        transition={{ duration: 0.8, ease: "easeOut" }}
      >
        <h1 className="project-hero-title">
          Jinan Huangtai Central Park
        </h1>
        <p className="project-description">
          This is a sandbox for you to build out the deeply customized, complex layout for Landscape Project 1. 
          You can add massive hero images, scroll-triggered animations (using framer-motion useScroll), 
          3D elements, or extensive text descriptions here.
        </p>
      </motion.div>
      
      {/* 留出大量空间以便测试上下滚动 */}
      <div className="project-placeholder-gallery">
        <span>[ Complex Gallery Area Placeholder for LProject 1 ]</span>
      </div>
    </div>
  );
}
</file>

